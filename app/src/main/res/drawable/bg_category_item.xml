<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/category_selected_bg" />
            <corners android:radius="@dimen/radius_card" />
            <stroke android:width="1dp" android:color="@color/primary_container" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/category_unselected_bg" />
            <corners android:radius="@dimen/radius_card" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
        </shape>
    </item>
</selector>
