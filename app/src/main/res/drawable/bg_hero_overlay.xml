<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/hero_overlay" />
            <corners android:radius="@dimen/radius_card_large" />
        </shape>
    </item>
    <item android:gravity="center_vertical|end" android:right="26dp">
        <shape android:shape="oval">
            <size android:width="86dp" android:height="86dp" />
            <stroke android:width="1dp" android:color="@color/hero_decor_light" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item android:gravity="top|start" android:top="24dp" android:left="24dp">
        <shape android:shape="oval">
            <size android:width="10dp" android:height="10dp" />
            <solid android:color="@color/hero_decor_light" />
        </shape>
    </item>
</layer-list>
