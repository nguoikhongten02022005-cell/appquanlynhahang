<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="25"
                android:endColor="@color/hero_gradient_end"
                android:startColor="@color/hero_gradient_start"
                android:centerColor="@color/hero_gradient_center"
                android:type="linear" />
            <corners android:radius="@dimen/radius_card_large" />
        </shape>
    </item>
    <item android:gravity="top|end" android:top="-20dp" android:right="-30dp">
        <shape android:shape="oval">
            <size android:width="180dp" android:height="180dp" />
            <solid android:color="@color/hero_glow" />
        </shape>
    </item>
    <item android:gravity="bottom|start" android:bottom="-36dp" android:left="-16dp">
        <shape android:shape="oval">
            <size android:width="150dp" android:height="150dp" />
            <solid android:color="@color/hero_decor_light" />
        </shape>
    </item>
</layer-list>
