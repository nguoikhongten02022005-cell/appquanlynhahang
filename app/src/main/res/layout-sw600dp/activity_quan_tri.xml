<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerAdminRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_surface_alt"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/layoutAdminSidebar"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:background="@color/admin_sidebar_bg"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_orange">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home_24"
                    app:tint="@color/white" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_role_admin"
                    android:textColor="@color/on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminRestaurantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_restaurant_name"
                    android:textColor="@color/admin_sidebar_text"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/admin_sidebar_divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/admin_sidebar_section_overview"
            android:textColor="@color/admin_sidebar_heading"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminTabOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_orange"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingTop="16dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp"
            android:text="@string/admin_tab_overview"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_menu_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/admin_sidebar_section_management"
            android:textColor="@color/admin_sidebar_heading"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminTabDishes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:text="@string/admin_tab_dishes"
            android:textAllCaps="false"
            android:textColor="@color/admin_sidebar_text"
            android:textSize="15sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_restaurant_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/admin_sidebar_text" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminOrdersShortcut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="center_vertical|start"
                android:minHeight="0dp"
                android:paddingStart="18dp"
                android:paddingTop="14dp"
                android:paddingEnd="18dp"
                android:paddingBottom="14dp"
                android:text="@string/admin_shortcut_orders"
                android:textAllCaps="false"
                android:textColor="@color/admin_sidebar_text"
                android:textSize="15sp"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_receipt_24"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/admin_sidebar_text" />

            <TextView
                android:id="@+id/tvAdminOrdersShortcutBadge"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text=""
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="3"
                tools:visibility="visible" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminReservationsShortcut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:text="@string/admin_shortcut_reservations"
            android:textAllCaps="false"
            android:textColor="@color/admin_sidebar_text"
            android:textSize="15sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_calendar_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/admin_sidebar_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminTabUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:text="@string/admin_tab_users"
            android:textAllCaps="false"
            android:textColor="@color/admin_sidebar_text"
            android:textSize="15sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_account_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/admin_sidebar_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/admin_sidebar_section_system"
            android:textColor="@color/admin_sidebar_heading"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminSettingsShortcut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:text="@string/admin_settings_title"
            android:textAllCaps="false"
            android:textColor="@color/admin_sidebar_text"
            android:textSize="15sp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_menu_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/admin_sidebar_text" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/admin_sidebar_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical|start"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/account_logout"
            android:textAllCaps="false"
            android:textColor="@color/error"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_remove_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/error" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/surface"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="28dp"
            android:paddingTop="22dp"
            android:paddingEnd="28dp"
            android:paddingBottom="22dp">

            <ImageView
                android:id="@+id/btnAdminOpenSidebar"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                android:src="@drawable/ic_menu_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/admin_header_title"
                android:textColor="@color/on_surface"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text="@string/admin_header_avatar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/layoutAdminOverview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/admin_surface_alt"
                android:fillViewport="true"
                android:paddingStart="28dp"
                android:paddingTop="24dp"
                android:paddingEnd="28dp"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_header_greeting"
                        android:textColor="@color/on_surface"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminCurrentDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textColor="@color/on_surface_variant"
                        android:textSize="16sp"
                        tools:text="16/04/2026" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="26dp"
                        android:columnCount="3"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/admin_stat_highlight"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminPendingDonHangsCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_pending_orders_short"
                                    android:textColor="@color/white"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminTotalDishesCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_total_dishes"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminPendingReservationsCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_pending_reservations"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminCustomerCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_customers"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminEmployeeCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_employees"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="22dp">

                                <TextView
                                    android:id="@+id/tvAdminTotalUsersCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/admin_stat_total_users"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="@string/admin_recent_orders_title"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutAdminRecentOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/tvAdminRecentOrdersEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/admin_recent_orders_empty"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="@string/admin_quick_actions_title"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAdminAddDishShortcut"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="20dp">

                                <FrameLayout
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="@color/primary_container">

                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_add_24"
                                        app:tint="@color/admin_stat_highlight" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:text="@string/admin_action_add_dish"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAdminReservationShortcut"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="20dp">

                                <FrameLayout
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="#E5F6EA">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="@string/admin_quick_action_checkmark"
                                        android:textColor="@color/admin_success"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:text="@string/admin_action_review_reservations"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvAdminTotalDonHangsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0" />

                        <TextView
                            android:id="@+id/tvAdminProcessingRequestsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0" />

                        <TextView
                            android:id="@+id/tvAdminAdminCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:id="@+id/layoutAdminDishes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/admin_surface_alt"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="24dp"
                android:paddingEnd="28dp"
                android:paddingBottom="28dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_dishes_title"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etAdminDishSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_search_rounded"
                    android:hint="@string/admin_search_dishes_hint"
                    android:padding="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminAddDish"
                    style="@style/Widget.Quanlynhahang.FilledButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/admin_add_dish" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAdminDishes"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvAdminDishesEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/admin_empty_dishes"
                    android:textColor="@color/on_surface_variant"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAdminUsers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/admin_surface_alt"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="24dp"
                android:paddingEnd="28dp"
                android:paddingBottom="28dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_users_title"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerAdminVaiTroNguoiDungFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAdminUsers"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvAdminUsersEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/admin_empty_users"
                    android:textColor="@color/on_surface_variant"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
