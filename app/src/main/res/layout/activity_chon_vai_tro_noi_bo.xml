<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/internal_role_picker_title"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/internal_role_picker_subtitle"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRoleEmployee"
        style="@style/Widget.Quanlynhahang.FilledButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/internal_role_employee" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRoleManager"
        style="@style/Widget.Quanlynhahang.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/internal_role_manager" />
</LinearLayout>
