<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <TextView
        android:id="@+id/tvCartTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_horizontal"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/screen_padding_horizontal"
        android:text="@string/cart_title"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCartSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_horizontal"
        android:layout_marginTop="@dimen/space_xs"
        android:layout_marginEnd="@dimen/screen_padding_horizontal"
        android:text="@string/cart_subtitle"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCartTitle" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollCartContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/space_md"
        app:layout_constraintBottom_toTopOf="@id/layoutCartFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCartSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/space_md">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Quanlynhahang.SurfaceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cart_context_title"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

                    <RadioGroup
                        android:id="@+id/rgCartOrderType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbCartDineIn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/order_type_dine_in" />

                        <RadioButton
                            android:id="@+id/rbCartTakeAway"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/order_type_take_away" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tvCartContextHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
                        tools:text="Nếu ăn tại quán, vui lòng nhập số bàn để nhân viên phục vụ đúng chỗ." />

                    <LinearLayout
                        android:id="@+id/layoutTableNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cart_table_label"
                            android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCartSelectTable"
                            style="@style/Widget.Quanlynhahang.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:gravity="center_vertical|start"
                            android:text="@string/cart_table_unselected"
                            app:icon="@drawable/ic_restaurant_24"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/cart_note_label"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle" />

                    <EditText
                        android:id="@+id/etCartNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:background="@drawable/bg_search_rounded"
                        android:gravity="top|start"
                        android:hint="@string/cart_note_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minHeight="90dp"
                        android:padding="@dimen/space_md"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/cart_items_title"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCartItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_mon_trong_don" />

            <TextView
                android:id="@+id/tvCartEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/cart_empty_message"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnContinueShopping"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:background="@drawable/bg_button_orange"
                android:text="@string/cart_continue_shopping"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnClearCart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_button_danger_outline"
                android:backgroundTint="@null"
                android:text="@string/cart_clear"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutCartFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="@dimen/space_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvCartSubtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody"
            tools:text="Tạm tính: 274.000 đ" />

        <TextView
            android:id="@+id/tvCartTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Tổng tiền: 274.000 đ" />

        <Button
            android:id="@+id/btnCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_button_green"
            android:text="@string/cart_checkout"
            android:textColor="@color/text_on_color"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
