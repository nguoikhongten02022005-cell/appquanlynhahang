<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <TextView
        android:id="@+id/tvCartTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_horizontal"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/screen_padding_horizontal"
        android:importantForAccessibility="yes"
        android:text="@string/cart_title"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollCartContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/space_md"
        app:layout_constraintBottom_toTopOf="@id/layoutCartFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCartTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/space_md">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Quanlynhahang.SurfaceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cart_context_title"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

                    <RadioGroup
                        android:id="@+id/rgCartOrderType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbCartDineIn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/order_type_dine_in" />

                        <RadioButton
                            android:id="@+id/rbCartTakeAway"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/order_type_take_away" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/layoutTableNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cart_table_label"
                            android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCartSelectTable"
                            style="@style/Widget.Quanlynhahang.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:gravity="center_vertical|start"
                            android:text="@string/cart_table_unselected"
                            app:icon="@drawable/ic_restaurant_24"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/cart_note_label"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle" />

                    <EditText
                        android:id="@+id/etCartNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:background="@drawable/bg_search_rounded"
                        android:gravity="top|start"
                        android:hint="@string/cart_note_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minHeight="90dp"
                        android:padding="@dimen/space_md"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/cart_items_title"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCartItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_mon_trong_don" />

            <LinearLayout
                android:id="@+id/layoutCartEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_dish_card"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/space_2xl"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/header_avatar_size"
                    android:layout_height="@dimen/header_avatar_size"
                    android:contentDescription="@string/cd_cart"
                    android:src="@drawable/ic_shopping_cart_24"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:text="@string/cart_empty_title"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:gravity="center"
                    android:text="@string/cart_empty_body"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueShopping"
                style="@style/Widget.Quanlynhahang.FilledButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:minHeight="@dimen/button_height"
                android:text="@string/cart_continue_shopping"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearCart"
                style="@style/Widget.Quanlynhahang.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:minHeight="@dimen/button_height"
                android:text="@string/cart_clear"
                android:textColor="@color/error"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutCartFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="@dimen/cart_footer_elevation"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/space_lg"
        android:paddingBottom="@dimen/space_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCartSubtotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody"
                tools:text="Tạm tính: 274.000 đ" />

            <TextView
                android:id="@+id/tvCartTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Tổng tiền: 274.000 đ" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckout"
            style="@style/Widget.Quanlynhahang.FilledButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:minHeight="@dimen/button_height"
            android:text="@string/cart_checkout"
            android:textSize="16sp"
            app:icon="@drawable/ic_shopping_cart_24"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/space_sm" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
