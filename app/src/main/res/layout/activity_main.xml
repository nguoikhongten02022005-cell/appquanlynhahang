<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".MainActivity">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:minHeight="@dimen/bottom_nav_min_height"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_bottom_nav" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLogo"
                    android:layout_width="@dimen/header_icon_box_size"
                    android:layout_height="@dimen/header_icon_box_size"
                    android:background="@drawable/bg_button_green"
                    android:gravity="center"
                    android:text="@string/logo_text"
                    android:textColor="@color/text_on_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/search_height"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_rounded"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md">

                    <ImageView
                        android:layout_width="@dimen/icon_size_20"
                        android:layout_height="@dimen/icon_size_20"
                        android:contentDescription="@string/cd_search"
                        android:src="@drawable/ic_search_24"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:text="@string/search_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="@dimen/header_icon_box_size"
                    android:layout_height="@dimen/header_icon_box_size"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:background="@drawable/bg_icon_circle">

                    <ImageView
                        android:layout_width="@dimen/icon_size_20"
                        android:layout_height="@dimen/icon_size_20"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_cart"
                        android:src="@drawable/ic_shopping_cart_24"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="@dimen/cart_badge_size"
                        android:layout_height="@dimen/cart_badge_size"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_badge_red"
                        android:gravity="center"
                        android:text="@string/cart_badge_count"
                        android:textColor="@color/text_on_color"
                        android:textSize="@dimen/cart_badge_text_size"
                        android:textStyle="bold" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/header_icon_box_size"
                    android:layout_height="@dimen/header_icon_box_size"
                    android:background="@drawable/bg_icon_circle">

                    <ImageView
                        android:layout_width="@dimen/icon_size_20"
                        android:layout_height="@dimen/icon_size_20"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_profile"
                        android:src="@drawable/ic_person_24"
                        app:tint="@color/text_primary" />
                </FrameLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/hero_height"
                android:layout_marginTop="@dimen/space_lg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_hero_placeholder"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_restaurant_24"
                        app:tint="@color/text_on_color" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_hero_overlay" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hero_title"
                            android:textColor="@color/text_on_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/hero_subtitle"
                            android:textColor="@color/text_on_color"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnHeroCta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:background="@drawable/bg_button_orange"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/space_lg"
                            android:paddingTop="@dimen/space_sm"
                            android:paddingEnd="@dimen/space_lg"
                            android:paddingBottom="@dimen/space_sm"
                            android:text="@string/hero_cta"
                            android:textAllCaps="false"
                            android:textColor="@color/text_on_color"
                            android:textSize="14sp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnQuickOrder"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/quick_action_height"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_green"
                    android:drawableStart="@drawable/ic_receipt_24"
                    android:drawablePadding="@dimen/space_sm"
                    android:drawableTint="@color/text_on_color"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/quick_action_order"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnQuickBook"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/quick_action_height"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_orange"
                    android:drawableStart="@drawable/ic_calendar_24"
                    android:drawablePadding="@dimen/space_sm"
                    android:drawableTint="@color/text_on_color"
                    android:gravity="center"
                    android:paddingStart="@dimen/space_md"
                    android:paddingEnd="@dimen/space_md"
                    android:text="@string/quick_action_book_table"
                    android:textAllCaps="false"
                    android:textColor="@color/text_on_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/pending_label"
                android:textColor="@color/brand_red"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/section_category"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingEnd="@dimen/space_sm"
                tools:listitem="@layout/item_category" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/section_recommended"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_recommended_dish" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
