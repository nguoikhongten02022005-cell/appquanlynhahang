<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerAdminRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_surface_alt"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layoutAdminShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/admin_surface_alt"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/quanTriFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/cardAdminBottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingTop="4dp"
            android:paddingEnd="2dp"
            android:paddingBottom="4dp">

            <FrameLayout
                android:id="@+id/btnAdminHeroSearch"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/navAdminOverview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_admin_bottom_nav_active"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/iconAdminOverview"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_home_24"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvAdminOverviewLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_bottom_nav_overview"
                    android:textColor="@color/brand_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAdminOrders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/iconAdminOrders"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_calendar_24"
                    app:tint="@color/nav_unselected" />

                <TextView
                    android:id="@+id/tvAdminOrdersLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_bottom_nav_orders"
                    android:textColor="@color/nav_unselected"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAdminTables"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/iconAdminTables"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_grid_24"
                    app:tint="@color/nav_unselected" />

                <TextView
                    android:id="@+id/tvAdminTablesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_bottom_nav_tables"
                    android:textColor="@color/nav_unselected"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAdminDishes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/iconAdminDishes"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_restaurant_24"
                    app:tint="@color/nav_unselected" />

                <TextView
                    android:id="@+id/tvAdminDishesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_bottom_nav_dishes"
                    android:textColor="@color/nav_unselected"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAdminAccounts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="58dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/iconAdminAccounts"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_account_24"
                    app:tint="@color/nav_unselected" />

                <TextView
                    android:id="@+id/tvAdminAccountsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_bottom_nav_accounts"
                    android:textColor="@color/nav_unselected"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
