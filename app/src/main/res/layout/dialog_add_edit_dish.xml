<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_dish_dialog_section_menu"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_dish_dialog_section_menu_desc"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/ivAdminDishPreview"
            android:layout_width="match_parent"
            android:layout_height="172dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_dish_image_placeholder"
            android:contentDescription="@string/cd_dish_image"
            android:padding="6dp"
            android:scaleType="centerCrop"
            android:src="@drawable/menu_1" />

        <TextView
            android:id="@+id/btnAdminDishPickImage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_table_secondary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/admin_dish_pick_image"
            android:textColor="@color/on_primary_container"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAdminDishImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/admin_dish_image_hint"
            android:inputType="text"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/admin_dish_name_hint"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/outline"
            app:helperText="@string/admin_dish_name_helper"
            app:helperTextTextColor="@color/on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAdminDishName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_price_hint"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/outline"
            app:helperText="@string/admin_dish_price_helper"
            app:helperTextTextColor="@color/on_surface_variant"
            app:prefixText="₫ ">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAdminDishPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_category_hint"
            app:boxBackgroundColor="@color/surface"
            app:boxCollapsedPaddingTop="6dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/outline"
            app:endIconTint="@color/on_surface_variant"
            app:helperText="@string/admin_dish_category_helper"
            app:helperTextTextColor="@color/on_surface_variant"
            app:hintTextColor="@color/primary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/autoCompleteAdminDishCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:completionThreshold="0"
                android:inputType="none"
                android:maxLines="1"
                android:minHeight="56dp"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_description_hint"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/outline"
            app:helperText="@string/admin_dish_description_helper"
            app:helperTextTextColor="@color/on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAdminDishDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_dish_available_switch"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_dish_status_helper"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbAdminDishAvailable"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:buttonTint="@color/brand_primary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
