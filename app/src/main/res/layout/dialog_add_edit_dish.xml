<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/etAdminDishName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/admin_dish_name_hint"
            android:inputType="textCapSentences" />

        <EditText
            android:id="@+id/etAdminDishPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_price_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/etAdminDishCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_category_hint"
            android:inputType="textCapSentences" />

        <EditText
            android:id="@+id/etAdminDishDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="@string/admin_dish_description_hint"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <EditText
            android:id="@+id/etAdminDishImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_image_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/etAdminDishScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/admin_dish_score_hint"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/cbAdminDishAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_dish_available_switch" />
    </LinearLayout>
</ScrollView>
