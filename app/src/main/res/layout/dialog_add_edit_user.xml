<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/etAdminUserName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/account_name_hint"
            android:importantForAutofill="no"
            android:inputType="textPersonName"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etAdminUserEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="@string/admin_user_email_hint"
            android:importantForAutofill="no"
            android:inputType="textEmailAddress"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etAdminUserPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="@string/account_phone_hint"
            android:importantForAutofill="no"
            android:inputType="phone"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etAdminUserPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="@string/account_new_password_hint"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLines="1" />

        <Spinner
            android:id="@+id/spinnerAdminUserRole"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp" />

        <Spinner
            android:id="@+id/spinnerAdminUserStatus"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp" />
    </LinearLayout>
</ScrollView>
