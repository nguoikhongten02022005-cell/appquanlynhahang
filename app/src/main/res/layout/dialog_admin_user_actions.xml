<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/tvAdminActionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/admin_user_action_title"
        android:textColor="@color/on_surface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAdminActionUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAdminActionUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvAdminActionUserPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvAdminActionUserStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_admin_role_chip"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:textColor="@color/brand_primary_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp"
        android:background="@color/outline_variant" />

    <TextView
        android:id="@+id/btnAdminUserEditAccount"
        style="@style/Widget.Quanlynhahang.AdminActionRow"
        android:text="@string/admin_user_edit_account" />

    <TextView
        android:id="@+id/btnAdminUserToggleStatus"
        style="@style/Widget.Quanlynhahang.AdminActionRow"
        android:textColor="@color/error" />

    <TextView
        android:id="@+id/btnAdminUserDeleteAccount"
        style="@style/Widget.Quanlynhahang.AdminActionRow"
        android:text="@string/admin_user_delete_account"
        android:textColor="@color/error" />
</LinearLayout>
