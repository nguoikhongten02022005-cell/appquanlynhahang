<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/space_lg"
    android:paddingEnd="@dimen/screen_padding_horizontal"
    android:paddingBottom="@dimen/space_md">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/activity_hub_title"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="@string/activity_hub_subtitle"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/hub_toggle_height"
        android:layout_marginTop="@dimen/space_lg"
        android:background="@drawable/bg_hub_toggle_group"
        android:orientation="horizontal"
        android:padding="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabOrders"
            style="@style/Widget.Quanlynhahang.TonalButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="@color/surface"
            android:text="@string/activity_hub_tab_orders"
            android:textStyle="bold"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabRequests"
            style="@style/Widget.Quanlynhahang.TonalButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:backgroundTint="@color/surface_variant"
            android:text="@string/activity_hub_tab_requests"
            android:textStyle="bold"
            app:strokeWidth="0dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/activityHubContentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_weight="1"
        android:background="@drawable/bg_hub_content" />
</LinearLayout>
