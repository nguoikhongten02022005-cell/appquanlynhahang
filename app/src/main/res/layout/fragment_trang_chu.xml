<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_lg"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/space_3xl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/hanhDongNhanhDonHang"
                android:layout_width="0dp"
                android:layout_height="@dimen/quick_action_height"
                android:layout_marginEnd="@dimen/space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_action_primary"
                android:gravity="center_vertical"
                android:minWidth="0dp"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <FrameLayout
                    android:layout_width="@dimen/quick_action_icon_box"
                    android:layout_height="@dimen/quick_action_icon_box"
                    android:background="@drawable/bg_icon_circle">

                    <ImageView
                        android:layout_width="@dimen/icon_size_20"
                        android:layout_height="@dimen/icon_size_20"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_menu_24"
                        app:tint="@color/brand_orange" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:maxLines="1"
                    android:text="@string/quick_action_order"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:maxLines="2"
                    android:text="@string/home_quick_order_subtitle"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionQuickBook"
                android:layout_width="0dp"
                android:layout_height="@dimen/quick_action_height"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_action_primary"
                android:gravity="center_vertical"
                android:minWidth="0dp"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <FrameLayout
                    android:layout_width="@dimen/quick_action_icon_box"
                    android:layout_height="@dimen/quick_action_icon_box"
                    android:background="@drawable/bg_icon_circle">

                    <ImageView
                        android:layout_width="@dimen/icon_size_20"
                        android:layout_height="@dimen/icon_size_20"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_calendar_24"
                        app:tint="@color/secondary" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:maxLines="1"
                    android:text="@string/quick_action_book_table"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:maxLines="2"
                    android:text="@string/home_quick_book_subtitle"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="@string/section_category"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="@dimen/space_xs"
            android:paddingEnd="@dimen/space_xs"
            tools:listitem="@layout/item_danh_muc_mon" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="@string/section_recommended"
                android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_mon_an_de_xuat" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
