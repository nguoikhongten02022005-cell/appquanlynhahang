<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutActivityHubRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/space_lg"
    android:paddingEnd="@dimen/screen_padding_horizontal"
    android:paddingBottom="@dimen/space_md">

    <TextView
        android:id="@+id/tvActivityHubTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/activity_hub_title"
        android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardServiceHubSummary"
        style="@style/Widget.Quanlynhahang.SurfaceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardUseCompatPadding="false">

        <LinearLayout
            android:id="@+id/layoutServiceHubSummaryContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvServiceHubSummaryTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle"
                    android:visibility="gone"
                    tools:text="Bạn đang ở Bàn 03"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvServiceHubSummaryOrder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody"
                    android:visibility="gone"
                    tools:text="Đang có đơn ăn tại quán hoạt động"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvServiceHubSummarySupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody"
                    android:visibility="gone"
                    tools:text="Có yêu cầu hỗ trợ đang chờ xử lý"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvServiceHubSummaryEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Quanlynhahang.CardBody"
                    android:visibility="gone"
                    tools:text=""
                    tools:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvServiceHubSummaryChevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/ky_hieu_mui_ten"
                android:textColor="@color/brand_orange"
                android:textSize="24sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/hub_toggle_height"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_hub_toggle_group"
        android:orientation="horizontal"
        android:padding="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabDonHangs"
            style="@style/Widget.Quanlynhahang.HubTabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="@color/surface"
            android:ellipsize="end"
            app:icon="@drawable/ic_receipt_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            android:maxLines="1"
            android:text="@string/activity_hub_tab_orders"
            android:textStyle="bold"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabRequests"
            style="@style/Widget.Quanlynhahang.HubTabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/surface_variant"
            android:ellipsize="end"
            app:icon="@drawable/ic_calendar_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            android:maxLines="1"
            android:text="@string/activity_hub_tab_service_requests"
            android:textStyle="bold"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabServiceRequests"
            style="@style/Widget.Quanlynhahang.HubTabButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/surface_variant"
            android:ellipsize="end"
            app:icon="@drawable/ic_person_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="16dp"
            android:maxLines="1"
            android:text="@string/activity_hub_tab_requests"
            android:textStyle="bold"
            app:strokeWidth="0dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/activityHubContentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1"
        android:background="@drawable/bg_hub_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_sm" />
</LinearLayout>
