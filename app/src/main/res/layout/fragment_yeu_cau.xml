<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/layoutServiceRequestRootContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/space_md">

        <TextView
            android:id="@+id/tvRequestsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/requests_screen_title"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.PageTitle" />

        <TextView
            android:id="@+id/tvServiceRequestSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/service_request_section_title"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

        <TextView
            android:id="@+id/tvServiceRequestCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/service_request_section_caption"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPendingServiceRequest"
            style="@style/Widget.Quanlynhahang.SurfaceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPendingServiceRequestTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Có yêu cầu hỗ trợ đang chờ xử lý"
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.CardTitle" />

                    <TextView
                        android:id="@+id/tvPendingServiceRequestSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="Nhấn để xem chi tiết trong danh sách hỗ trợ."
                        android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/brand_orange"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestCallStaff"
                    style="@style/Widget.Quanlynhahang.FilledButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:maxLines="1"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingEnd="@dimen/space_sm"
                    android:text="@string/service_request_quick_call_staff"
                    android:textSize="13sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestMoreWater"
                    style="@style/Widget.Quanlynhahang.FilledButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:maxLines="1"
                    android:paddingStart="@dimen/space_sm"
                    android:paddingEnd="@dimen/space_sm"
                    android:text="@string/service_request_quick_more_water"
                    android:textSize="13sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequestPayment"
                style="@style/Widget.Quanlynhahang.FilledButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:minHeight="0dp"
                android:maxLines="1"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_sm"
                android:text="@string/service_request_quick_request_payment"
                android:textSize="13sp"
                app:autoSizeMaxTextSize="13sp"
                app:autoSizeMinTextSize="11sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/service_request_list_title"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServiceRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_yeu_cau_phuc_vu" />

        <TextView
            android:id="@+id/tvServiceRequestEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:gravity="center"
            android:text="@string/service_request_empty_message"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
