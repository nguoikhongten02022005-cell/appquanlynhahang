<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvYeuCauNoiBoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/employee_service_requests_title"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/employee_service_requests_description"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvYeuCauNoiBoEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/employee_empty_service_requests"
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvYeuCauNoiBo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />
</LinearLayout>
