<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/category_item_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/space_md"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="@dimen/category_circle_size"
        android:layout_height="@dimen/category_circle_size"
        android:background="@drawable/bg_category_circle">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="@dimen/icon_size_24"
            android:layout_height="@dimen/icon_size_24"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_category_icon"
            android:src="@drawable/ic_restaurant_24"
            android:tint="@color/brand_green" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/category_main_course"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
