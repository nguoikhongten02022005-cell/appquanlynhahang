<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/category_item_width"
    android:layout_height="@dimen/category_card_height"
    android:layout_marginEnd="@dimen/space_md"
    android:background="@drawable/bg_category_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/space_md">

    <FrameLayout
        android:id="@+id/categoryIconContainer"
        android:layout_width="@dimen/category_circle_size"
        android:layout_height="@dimen/category_circle_size"
        android:background="@drawable/bg_category_circle">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="@dimen/icon_size_24"
            android:layout_height="@dimen/icon_size_24"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_category_icon"
            android:src="@drawable/ic_restaurant_24"
            app:tint="@color/category_unselected_icon" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/category_main_course"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
