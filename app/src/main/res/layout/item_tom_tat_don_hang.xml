<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_md"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dish_card"
        android:orientation="vertical"
        android:padding="@dimen/space_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDonHangCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="#DH12345" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDonHangStatus"
                style="@style/Widget.Quanlynhahang.StatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_green"
                android:text="@string/order_status_pending"
                android:textColor="@color/text_on_color"
                app:backgroundTint="@color/brand_orange" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDonHangTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="12/03/2026 10:30" />

        <TextView
            android:id="@+id/tvDonHangType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Ăn tại quán" />

        <TextView
            android:id="@+id/tvDonHangTable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Bàn: Bàn 03" />

        <TextView
            android:id="@+id/tvDonHangPayment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Thanh toán: Chưa thanh toán" />

        <TextView
            android:id="@+id/tvDonHangNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Ghi chú: Ít cay" />

        <TextView
            android:id="@+id/tvDonHangTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textColor="@color/brand_orange"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="500.000 đ" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDonHangDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:minHeight="0dp"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:text="@string/order_view_details"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDonHangCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_button_orange"
                android:minHeight="0dp"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:text="@string/order_cancel"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDonHangDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/order_detail_dishes_title"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMonTrongDon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_mon_trong_don" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
