<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Quanlynhahang.SurfaceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/account_edit_profile_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etEditName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:hint="@string/account_name_hint"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etEditPhone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:hint="@string/account_phone_hint"
            android:inputType="phone"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelEditProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:minHeight="0dp"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm"
                android:text="@string/account_cancel_action"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                app:backgroundTint="@null" />

            <Space
                android:layout_width="@dimen/space_sm"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfileChanges"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:minHeight="0dp"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm"
                android:text="@string/account_save_changes"
                android:textAllCaps="false"
                android:textColor="@color/text_on_color"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
