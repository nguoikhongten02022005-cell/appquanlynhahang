<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dish_card"
        android:orientation="vertical"
        android:padding="@dimen/space_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/account_edit_profile_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etEditName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:hint="@string/account_name_hint"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etEditPhone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:hint="@string/account_phone_hint"
            android:inputType="phone"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfileChanges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_button_green"
            android:minHeight="0dp"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_sm"
            android:text="@string/account_save_changes"
            android:textAllCaps="false"
            android:textColor="@color/text_on_color"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
