<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Quanlynhahang.SurfaceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reservation_date_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReservationDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@drawable/bg_search_rounded"
            android:clickable="true"
            android:drawablePadding="@dimen/space_sm"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="@dimen/search_height"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_sm"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_sm"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:drawableEndCompat="@drawable/ic_calendar_24"
            tools:text="15/03/2026" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/reservation_time_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReservationTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@drawable/bg_search_rounded"
            android:clickable="true"
            android:drawablePadding="@dimen/space_sm"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="@dimen/search_height"
            android:paddingStart="@dimen/space_md"
            android:paddingTop="@dimen/space_sm"
            android:paddingEnd="@dimen/space_md"
            android:paddingBottom="@dimen/space_sm"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:drawableEndCompat="@drawable/ic_calendar_24"
            tools:text="19:00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/reservation_area_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:boxStrokeColor="@color/outline"
            app:endIconTint="@color/text_secondary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/autoCompleteReservationTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:completionThreshold="0"
                android:hint="@string/reservation_table_picker_hint"
                android:inputType="none"
                android:maxLines="1"
                android:minHeight="@dimen/search_height"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvReservationAvailableTables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
            android:textColor="@color/success" />

        <TextView
            android:id="@+id/tvReservationOccupiedTables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption"
            android:textColor="@color/error" />

        <EditText
            android:id="@+id/etGuestCount"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:hint="@string/reservation_guest_count_hint"
            android:inputType="number"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etReservationNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_search_rounded"
            android:gravity="top|start"
            android:hint="@string/reservation_note_hint"
            android:inputType="textCapSentences|textMultiLine"
            android:minHeight="90dp"
            android:padding="@dimen/space_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/reservation_validation_hint"
            android:textAppearance="@style/TextAppearance.Quanlynhahang.SectionCaption" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitReservation"
            style="@style/Widget.Quanlynhahang.FilledButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:minHeight="0dp"
            android:text="@string/reservation_submit"
            android:textSize="14sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
