<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.Quanlynhahang.PageTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Quanlynhahang.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Quanlynhahang.SectionCaption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="TextAppearance.Quanlynhahang.CardTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Quanlynhahang.CardBody" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Quanlynhahang.SurfaceCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="Widget.Quanlynhahang.FilledButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="iconTint">@color/on_secondary</item>
        <item name="rippleColor">@color/ripple_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Quanlynhahang.AccentButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="iconTint">@color/on_secondary</item>
        <item name="rippleColor">@color/ripple_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Quanlynhahang.TonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="iconTint">@color/primary</item>
        <item name="rippleColor">@color/ripple_neutral</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Quanlynhahang.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:minHeight">@dimen/bottom_nav_min_height</item>
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Quanlynhahang.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Quanlynhahang.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_indicator</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Quanlynhahang.NavIndicator</item>
        <item name="android:width">64dp</item>
        <item name="android:height">32dp</item>
    </style>

    <style name="ShapeAppearance.Quanlynhahang.NavIndicator" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
